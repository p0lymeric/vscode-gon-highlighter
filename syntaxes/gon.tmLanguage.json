{
    "information_for_contributors": [
        "polymeric 2026. MIT License.",
        "Based off VS Code's JSONC TextMate grammar. Copyright (c) 2015 - present Microsoft Corporation. MIT License.",
        "https://github.com/TylerGlaiel/GON",
        "https://github.com/microsoft/vscode/blob/80cf9e47b373d416c1a9fef061caabe8bfd598b5/extensions/json/syntaxes/JSONC.tmLanguage.json",
        "https://github.com/microsoft/vscode/blob/d188e2d1096bc4c9251c5d293d013e12e44ffc48/extensions/yaml/syntaxes/yaml-1.1.tmLanguage.json",
        "https://github.com/microsoft/vscode/blob/5ebbe53282bd1d5d3453405d9e6a34ee2eb7f42d/extensions/cpp/syntaxes/c.tmLanguage.json",
        "https://macromates.com/manual/en/language_grammars"
    ],

    "version": "2.0.4",
    "name": "GON (Glaiel Object Notation)",
    "scopeName": "source.gon",

    "patterns": [
        { "include": "#preprocessor" },
        { "include": "#keyvalue" }
    ],

    "comment": [
        "Fusion[1] is just a cheap[2] tactic[3] to make weak Gems[4] stronger[5]!",

        "[1] fusing regular expression matchers",
        "[2] suitable for Era 1 computers (~2004), still conventional in Era 2 (~2026)",
        "[3] classy Gems wish to write grammars in an EBNF-like format, but alas, the Diamonds killed R&D on the initiative[6]",
        "[4] sp. Oniguruma, of Ruby fame (though some say her unaugmented powers already extend beyond Type-3 class)",
        "[5] typically from Type-3 to Type-2/1",
        "[6] see: https://github.com/microsoft/vscode/pull/161479"
    ],

    "repository": {
        "preprocessor_include": {
            "begin": "((#)(include))\\b\\s*",
            "beginCaptures": {
                "1": { "name": "keyword.control.directive.gon" },
                "2": { "name": "punctuation.definition.directive.include.gon" }
            },
            "end": "(?=\\s|$)",
            "name": "meta.preprocessor.include.gon",
            "patterns": [
                {
                    "begin": "\"",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.string.begin.gon" }
                    },
                    "end": "\"",
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.string.end.gon" }
                    },
                    "name": "string.quoted.double.include.gon"
                },
                {
                    "match": "[^\\s\"]+",
                    "name": "string.unquoted.include.gon"
                }
            ]
        },

        "preprocessor_comment": {
            "patterns": [
                {
                    "begin": "/\\*",
                    "captures": {
                        "0": { "name": "punctuation.definition.comment.gon" }
                    },
                    "end": "\\*/",
                    "name": "comment.block.gon"
                },
                {
                    "match": "(//).*",
                    "captures": {
                        "1": { "name": "punctuation.definition.comment.gon" }
                    },
                    "name": "comment.line.double-slash.gon"
                },
                {
                    "match": "(#)#*(?:[ \t].*|$)",
                    "captures": {
                        "1": { "name": "punctuation.definition.comment.gon" }
                    },
                    "comment": "Hash comments are actually eaten by the GON parser, not the preprocessor",
                    "comment2": "(the # sigil can either be interpreted as a macro use directive or passed through to GON)",
                    "comment3": "We give identical highlighting precedence to GON and preprocessor comments for simpicity.",
                    "name": "comment.line.number-sign.gon"
                }
            ]
        },

        "preprocessor_define": {
            "begin": "((#)(define))\\b",
            "beginCaptures": {
                "1": { "name": "keyword.control.directive.macro.gon" },
                "2": { "name": "punctuation.definition.directive.gon" }
            },
            "end": "((#)(end))\\b",
            "endCaptures": {
                "1": { "name": "keyword.control.directive.end.gon" },
                "2": { "name": "punctuation.definition.directive.gon" }
            },
            "name": "meta.preprocessor.define.gon",
            "patterns": [
                { "include": "#preprocessor_comment" },
                { "include": "#preprocessor_define_name" }
            ]
        },
        "preprocessor_define_name": {
            "begin": "((?:[^\\s(/]|/(?![/*]))+)",
            "beginCaptures": {
                "1": { "name": "entity.name.function.gon" }
            },
            "end": "(?=((#)(end))\\b)",
            "patterns": [
                { "include": "#preprocessor_comment" },
                { "include": "#preprocessor_define_params" },
                { "include": "#preprocessor_define_body" }
            ]
        },
        "preprocessor_define_body": {
            "begin": "(?<=\\))|(?=[^\\s(])",
            "end": "(?=((#)(end))\\b)",
            "patterns": [
                { "include": "#preprocessor_comment" },
                { "include": "#value" }
            ]
        },
        "preprocessor_define_params": {
            "begin": "\\(",
            "beginCaptures": {
                "0": { "name": "punctuation.section.parameters.begin.bracket.round.gon" }
            },
            "end": "\\)",
            "endCaptures": {
                "0": { "name": "punctuation.section.parameters.end.bracket.round.gon" }
            },
            "patterns": [
                { "include": "#preprocessor_comment" },
                {
                    "match": "(?:[^\\s,:=\\[\\]{}()/]|/(?![/*]))+",
                    "name": "variable.parameter.gon"
                }
            ]
        },

        "preprocessor_macro": {
            "begin": "((#)((?:[^\\s\\[\\]{}\"#,=:/]|/(?![/*]))+))\\b",
            "beginCaptures": {
                "1": { "name": "keyword.control.directive.macro.gon" },
                "2": { "name": "punctuation.definition.directive.gon" }
            },
            "comment": "Here we presume the macro invocation will absorb the rest of the line, which disagrees with the real preprocessor.",
            "comment2": "Since macros absorb a variable number of words, it is impossible to correctly colour them with TextMate's grammar descriptions.",
            "end": "$",
            "name": "meta.preprocessor.macro.gon",
            "patterns": [
                { "include": "#preprocessor_comment" },
                { "include": "#value" }
            ]
        },

        "constant": {
            "match": "(?:true|false|null)(?!(?:[^\\s\\[\\]{}\"#,=:/]|/(?![/*])))",
            "name": "constant.language.gon"
        },
        "number": {
            "comment": "These are aligned against strtol base 0/strtod's parsing",
            "patterns": [
                {
                    "match": "[+-]?(?:0[xX][0-9a-fA-F]+|0[0-7]*|[1-9][0-9]*)(?!(?:[^\\s\\[\\]{}\"#,=:/]|/(?![/*])))",
                    "name": "constant.numeric.gon"
                },
                {
                    "match": "[+-]?(?:[0-9]+\\.?[0-9]*|[0-9]*\\.[0-9]+)(?:[eE][+-]?[0-9]+)?(?!(?:[^\\s\\[\\]{}\"#,=:/]|/(?![/*])))",
                    "name": "constant.numeric.gon"
                },
                {
                    "match": "[+-]?0[xX](?:[0-9a-fA-F]+\\.?[0-9a-fA-F]*|[0-9a-fA-F]*\\.[0-9a-fA-F]+)(?:[pP][+-]?[0-9]+)?(?!(?:[^\\s\\[\\]{}\"#,=:/]|/(?![/*])))",
                    "name": "constant.numeric.gon"
                },
                {
                    "match": "(?i)[+-]?(?:infinity|inf|nan(?:\\([0-9a-zA-Z_]*\\))?)(?!(?:[^\\s\\[\\]{}\"#,=:/]|/(?![/*])))",
                    "name": "constant.numeric.gon"
                }
            ]
        },
        "string": {
            "begin": "\"",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.string.begin.gon" }
            },
            "end": "\"",
            "endCaptures": {
                "0": { "name": "punctuation.definition.string.end.gon" }
            },
            "name": "string.quoted.double.gon",
            "patterns": [
                { "include": "#stringcontent" }
            ]
        },
        "array": {
            "begin": "\\[",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.array.begin.gon" }
            },
            "end": "\\]",
            "endCaptures": {
                "0": { "name": "punctuation.definition.array.end.gon" }
            },
            "name": "meta.structure.array.gon",
            "patterns": [
                { "include": "#preprocessor" },
                { "include": "#value" }
            ]
        },
        "object": {
            "begin": "\\{",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.dictionary.begin.gon" }
            },
            "end": "\\}",
            "endCaptures": {
                "0": { "name": "punctuation.definition.dictionary.end.gon" }
            },
            "name": "meta.structure.dictionary.gon",
            "patterns": [
                { "include": "#preprocessor" },
                { "include": "#keyvalue" }
            ]
        },
        "unquoted": {
            "match": "(?:[^\\s\\[\\]{}\"#,=:/]|/(?![/*]))+",
            "name": "string.unquoted.plain.gon"
        },

        "stringcontent": {
            "patterns": [
                {
                    "match": "\\\\(?:n|\\\\|\")",
                    "name": "constant.character.escape.gon"
                },
                {
                    "match": "\\\\.",
                    "name": "constant.character.escape.other.gon"
                }
            ]
        },
        "keyvalue": {
            "begin": "(?:(\"[^\"]*\")|((?:[^\\s\\[\\]{}\"#,=:/]|/(?![/*]))+))((?:\\s*(?://[^\\n]*|/\\*[\\s\\S]*?\\*/))+\\s*|\\s+|[ \\t]*[=:][ \\t]*|(?=\\S|$))",
            "beginCaptures": {
                "1": {
                    "name": "string.quoted.double.gon entity.name.tag.gon",
                    "patterns": [
                        { "include": "#stringcontent" }
                    ]
                },
                "2": { "name": "string.unquoted.plain.gon entity.name.tag.gon" },
                "3": {
                    "patterns": [
                        { "include": "#preprocessor_comment" }
                    ]
                }
            },
            "comment": "If a value is a quoted string that spans multiple lines, it will fail to parse correctly.",
            "comment2": "(keys can span multiple lines by sheer coincidence of being parsed as two keyvalues)",
            "end": "(?<=[\"\\}\\]])(?=\\s|$|[,\\}\\]]|//|/\\*|#)|(?<=[^\\s\\[\\]{}\"#,=:])(?<!\\*/)(?=\\s|$|[,\\}\\]]|//|/\\*)",
            "patterns": [
                { "include": "#value" }
            ]
        },
        "preprocessor": {
            "patterns": [
                { "include": "#preprocessor_comment" },
                { "include": "#preprocessor_include" },
                { "include": "#preprocessor_define" },
                { "include": "#preprocessor_macro" }
            ]
        },
        "value": {
            "comment": "#include and macro invocations in a value position are assumed to have odd parity",
            "patterns": [
                { "include": "#preprocessor_include" },
                { "include": "#preprocessor_macro" },
                { "include": "#constant" },
                { "include": "#number" },
                { "include": "#string" },
                { "include": "#array" },
                { "include": "#object" },
                { "include": "#unquoted" }
            ]
        }
    }
}
