// SYNTAX TEST "source.gon" "Preprocessor directives"

#include "file.gon"
// <- punctuation.definition.directive.include.gon
// <-------- keyword.control.directive.gon
//       ^ punctuation.definition.string.begin.gon
//       ^^^^^^^^^^ string.quoted.double.include.gon
//                ^ punctuation.definition.string.end.gon
// <------------------ meta.preprocessor.include.gon

#include path/to/file.gon
// <- punctuation.definition.directive.include.gon
// <-------- keyword.control.directive.gon
//       ^^^^^^^^^^^^^^^^ string.unquoted.include.gon
// <------------------------ meta.preprocessor.include.gon

#define macro
// <- punctuation.definition.directive.gon
// <------- keyword.control.directive.macro.gon
//      ^^^^^ entity.name.function.gon
    key value
//  ^^^ string.unquoted.plain.gon
//      ^^^^^ string.unquoted.plain.gon
#end
// <- punctuation.definition.directive.gon
// <---- keyword.control.directive.end.gon

#define macro meow #end
// <- punctuation.definition.directive.gon
// <------- keyword.control.directive.macro.gon
//      ^^^^^ entity.name.function.gon
//            ^^^^ string.unquoted.plain.gon
//                 ^ punctuation.definition.directive.gon
//                 ^^^^ keyword.control.directive.end.gon

#define macro(marco, polo)
// <- punctuation.definition.directive.gon
// <------- keyword.control.directive.macro.gon
//      ^^^^^ entity.name.function.gon
//           ^ punctuation.section.parameters.begin.bracket.round.gon
//            ^^^^^ variable.parameter.gon
//                   ^^^^ variable.parameter.gon
//                       ^ punctuation.section.parameters.end.bracket.round.gon
#end
// <- punctuation.definition.directive.gon
// <---- keyword.control.directive.end.gon

#define macro(marco polo)
// <- punctuation.definition.directive.gon
// <------- keyword.control.directive.macro.gon
//      ^^^^^ entity.name.function.gon
//           ^ punctuation.section.parameters.begin.bracket.round.gon
//            ^^^^^ variable.parameter.gon
//                  ^^^^ variable.parameter.gon
//                      ^ punctuation.section.parameters.end.bracket.round.gon
#end
// <- punctuation.definition.directive.gon
// <---- keyword.control.directive.end.gon

#define // i'm a comment
// <- punctuation.definition.directive.gon
// <------- keyword.control.directive.macro.gon
/* another comment */ macro
//                    ^^^^^ entity.name.function.gon
(
// <- punctuation.section.parameters.begin.bracket.round.gon
    /**/marco,
//      ^^^^^ variable.parameter.gon
    polo//
//  ^^^^ variable.parameter.gon
)  body
// ^^^^ string.unquoted.plain.gon
// <- punctuation.section.parameters.end.bracket.round.gon
#end
// <- punctuation.definition.directive.gon
// <---- keyword.control.directive.end.gon

#macro rest of line
// <- punctuation.definition.directive.gon
// <----- keyword.control.directive.macro.gon
//    ^^^^^^^^^^^^^ meta.preprocessor.macro.gon
