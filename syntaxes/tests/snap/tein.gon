// Excerpted from data/tilesets.txt
i1 {
    tile_graphics Tileretro
    overlay_graphics Overlaysretro
    background_graphics bgretrox
    foreground_graphics none
    palette 46

    cart_intro_png Denial
    cart_intro_palette 46

    music [retro/requiem_intro.ogg, retro/requiem_loop.ogg]

    music_volume 1
    ambience_volume 1

    area_type ironcart

    art_alts [
        [Player, PlayerRetro][Frog, Frogretro][Floater, RetroGhost][Slug, Slugretro]
        [SkullFloater, SkullFloaterretro][Gasser, Gasserretro][Splatter, Splatterretro][CheepCheep, cheepretro][Bullet, bulletretro]
        [SpitterX, SpitterXretro][SpitterY, SpitterYretro][AimSpitter, SpitterZretro][Cannonball, cannonballretro][Fireball, cannonballfireretro]
        [Hopper, hopperretro][SkullSlug, SkullSlugretro][SkullCrow, SkullCrowretro][ChainChomp, ChainChompretro][ChainLink, ChainLinkretro][ChainLink2, ChainLinkretro]
        [Mask, Maskretro][Revolver, Revolverretro][GasCloud, GasCloudretro][Cannon,Cannonretro][Cannonstand,Cannonstandretro][Bouncer,Bouncerretro]
        [ElectroBall, RetroElectroBall][OrbSmall, RetroOrbSmall][OrbLarge, RetroOrbLarge][ChargeSlug, RetroChargerSlug]
        [Fish, RetroFish][CreepingMass, CreepingMassRetro]
    ]

}

// Excerpted from data/npcs.txt
NPCH4 {
