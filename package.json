{
    "name": "vscode-gon-highlighter",
    "displayName": "%displayName%",
    "description": "%description%",
    "icon": "images/icon.png",
    "version": "2.0.4",
    "publisher": "polymeric",
    "license": "MIT",
    "engines": {
        "vscode": "^1.100.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "main": "./dist/extension.main.js",
    "browser": "./dist/extension.browser.js",
    "contributes": {
        "languages": [
            {
                "id": "gon",
                "aliases": [
                    "GON",
                    "Glaiel Object Notation",
                    "gon"
                ],
                "extensions": [
                    ".gon",
                    ".gon.append",
                    ".gon.merge",
                    ".gon.patch"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "gon",
                "scopeName": "source.gon",
                "path": "./syntaxes/gon.tmLanguage.json"
            }
        ],
        "configuration": {
            "title": "%displayName%",
            "properties": {
                "gonHighlighter.enable": {
                    "type": "boolean",
                    "default": true,
                    "description": "%configuration.gonHighlighter.enable.description%"
                },
                "gonHighlighter.enableDiagnostics": {
                    "type": "boolean",
                    "default": true,
                    "description": "%configuration.gonHighlighter.enableDiagnostics.description%"
                },
                "gonHighlighter.enableOutline": {
                    "type": "boolean",
                    "default": true,
                    "description": "%configuration.gonHighlighter.enableOutline.description%"
                }
            }
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/p0lymeric/vscode-gon-highlighter.git"
    },
    "scripts": {
        "precompile": "npm install",
        "compile": "npm run check-types && node esbuild.js",
        "check-types": "tsc --noEmit",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "vscode:prepublish": "npm run package",
        "package": "npm run check-types && node esbuild.js --production",
        "run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. .",
        "clean": "npx rimraf dist node_modules .vscode-test-web tsconfig.tsbuildinfo",
        "test:unit": "textmate-grammar-test syntaxes/tests/unit/**/*.gon",
        "test:snap": "textmate-grammar-snap syntaxes/tests/snap/**/*.gon"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.11"
    },
    "devDependencies": {
        "@types/node": "^22",
        "@types/vscode": "^1.100.0",
        "@vscode/test-web": "^0.0.80",
        "esbuild": "^0.28.0",
        "rimraf": "^6.1.3",
        "textmate-grammar-test": "^0.6.0",
        "typescript": "^5.9.2"
    }
}
